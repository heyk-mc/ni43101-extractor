# =============================
# NI 43-101 提取系统环境变量配置
# =============================

# -----------------------------
# DeepSeek API (Extractor Agent)
# -----------------------------
# 获取地址：https://platform.deepseek.com/settings/api-key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-pro

# -----------------------------
# DashScope API (CriticMaster Agent - Qwen)
# -----------------------------
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# 如果不使用 Qwen，可注释掉或留空
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen3.5-plus

# -----------------------------
# 日志配置
# -----------------------------
LOG_LEVEL=INFO
# 可选：DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------
# 系统配置
# -----------------------------
# 最大修订轮次 (默认 3)
MAX_REVISE_ROUNDS=3

# 评分阈值 (低于此分数触发修订，默认 8)
SCORE_THRESHOLD=8

# 容差百分比 (用于评测，默认 0.05 表示±5%)
TOLERANCE_PERCENT=0.05

# -----------------------------
# 路径配置
# -----------------------------
# PDF 文件目录 (相对于项目根目录)
PDF_DATA_DIR=data/pdfs

# 进化日志路径 (相对于项目根目录)
EVOLUTION_LOG_PATH=data/evolution.jsonl

# 日志目录 (相对于项目根目录)
LOG_DIR=logs
